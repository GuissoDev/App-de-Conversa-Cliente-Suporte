<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="ConteinerComponents">
        <item name="android:layout_width">@dimen/container_width</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:background">@drawable/conteiner_components</item>
        <item name="android:layout_margin">@dimen/container_margin</item>
    </style>

    <style name="Edit_Text">
        <item name="android:layout_width">0dp</item> <!-- Use 0dp com constraints para respeitar a largura do container -->
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/edyt_text</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:padding">16dp</item>
        <item name="android:layout_marginLeft">@dimen/edit_text_margin_side</item>
        <item name="android:layout_marginRight">@dimen/edit_text_margin_side</item>
    </style>

    <style name="Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:padding">16dp</item>
        <item name="android:textSize">@dimen/text_size_large</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:background">@drawable/button</item>
        <item name="android:layout_marginLeft">@dimen/edit_text_margin_side</item>
        <item name="android:layout_marginRight">@dimen/edit_text_margin_side</item>
        <item name="android:textStyle">bold</item>
        <item name="textAllCaps">false</item>
    </style>

    </resources>