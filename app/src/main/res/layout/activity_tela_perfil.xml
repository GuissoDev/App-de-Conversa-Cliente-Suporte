<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/container_user"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    tools:context=".Fragment.TelaPerfil">

    <View
        android:id="@+id/containeruser"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:background="@drawable/container_user"
        android:layout_marginTop="60dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        />

        <ImageView
            android:id="@+id/img_perfil"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:src="@drawable/ic_person"
            android:scaleType="centerCrop"
            app:layout_constraintStart_toStartOf="@id/containeruser"
            app:layout_constraintEnd_toEndOf="@id/containeruser"
            app:layout_constraintTop_toTopOf="@id/containeruser"
            app:layout_constraintBottom_toBottomOf="@id/containeruser"/>

    <ImageView
        android:id="@+id/btn_alterar_foto"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/circle_unread"
        android:backgroundTint="@color/Green"
        android:clickable="true"
        android:contentDescription="Alterar foto de perfil"
        android:focusable="true"
        android:padding="12dp"
        android:src="@drawable/ic_cam"
        app:layout_constraintBottom_toBottomOf="@id/containeruser"
        app:layout_constraintEnd_toEndOf="@id/containeruser"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="@id/containeruser"
        app:layout_constraintTop_toTopOf="@id/containeruser"
        app:layout_constraintVertical_bias="1.0"
        app:tint="@color/white" />

    <TextView
        android:id="@+id/text_user_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        app:layout_constraintTop_toBottomOf="@id/containeruser"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp" />

    <View
        android:id="@+id/card_perfil"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="30dp"
        android:background="@drawable/conteiner_components"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_user_header"
        app:layout_constraintBottom_toBottomOf="@id/btn_deslogar"
        app:layout_constraintWidth_max="500dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="-40dp"
        />

    <ImageView
        android:id="@+id/ic_user"
        android:layout_width="35dp"
        android:layout_height="35dp"
        android:src="@drawable/ic_person"
        app:tint="@color/Green"
        app:layout_constraintStart_toStartOf="@id/card_perfil"
        app:layout_constraintTop_toTopOf="@id/card_perfil"
        android:layout_marginTop="30dp"
        android:layout_marginLeft="25dp"/>

    <TextView
        android:id="@+id/text_user"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        app:layout_constraintTop_toTopOf="@id/ic_user"
        app:layout_constraintBottom_toBottomOf="@id/ic_user"
        app:layout_constraintStart_toEndOf="@id/ic_user"
        app:layout_constraintEnd_toEndOf="@id/card_perfil"
        android:layout_marginLeft="15dp"
        android:layout_marginRight="15dp"/>

    <ImageView
        android:id="@+id/ic_emailUser"
        android:layout_width="35dp"
        android:layout_height="35dp"
        android:src="@drawable/ic_email"
        app:tint="@color/Green"
        app:layout_constraintStart_toStartOf="@id/card_perfil"
        app:layout_constraintTop_toBottomOf="@id/ic_user"
        android:layout_marginTop="20dp"
        android:layout_marginLeft="25dp"/>

    <TextView
        android:id="@+id/text_EmailUser"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="18sp"
        android:textColor="@color/black"
        app:layout_constraintTop_toTopOf="@id/ic_emailUser"
        app:layout_constraintBottom_toBottomOf="@id/ic_emailUser"
        app:layout_constraintStart_toEndOf="@id/ic_emailUser"
        app:layout_constraintEnd_toEndOf="@id/card_perfil"
        android:layout_marginLeft="15dp"
        android:layout_marginRight="15dp"/>

    <ImageView
        android:id="@+id/ic_PhoneUser"
        android:layout_width="35dp"
        android:layout_height="35dp"
        android:src="@drawable/ic_phone"
        app:tint="@color/Green"
        app:layout_constraintStart_toStartOf="@id/card_perfil"
        app:layout_constraintTop_toBottomOf="@id/ic_emailUser"
        android:layout_marginTop="25dp"
        android:layout_marginLeft="25dp"/>

    <LinearLayout
        android:id="@+id/phone_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="@id/ic_PhoneUser"
        app:layout_constraintBottom_toBottomOf="@id/ic_PhoneUser"
        app:layout_constraintStart_toEndOf="@id/ic_PhoneUser"
        app:layout_constraintEnd_toEndOf="@id/card_perfil"
        android:layout_marginLeft="15dp"
        android:layout_marginRight="15dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+55 "
            android:textSize="18sp"
            android:textColor="@color/black"/>

        <TextView
            android:id="@+id/text_PhoneUser"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="18sp"
            android:textColor="@color/black"/>
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_deslogar"
        style="@style/Button"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Sair da Conta"
        android:layout_marginTop="40dp"
        app:layout_constraintStart_toStartOf="@id/card_perfil"
        app:layout_constraintEnd_toEndOf="@id/card_perfil"
        app:layout_constraintTop_toBottomOf="@id/phone_layout"
        app:layout_constraintWidth_default="spread"
        android:layout_marginHorizontal="25dp"
        />

</androidx.constraintlayout.widget.ConstraintLayout>